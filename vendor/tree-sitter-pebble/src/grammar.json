{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "pebble",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "text"
          },
          {
            "type": "SYMBOL",
            "name": "output"
          },
          {
            "type": "SYMBOL",
            "name": "directive"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          }
        ]
      }
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^{}]+|[{}]"
        }
      }
    },
    "output": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "template_item"
          }
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{%"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            },
            "named": true,
            "value": "tag_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "template_item"
          }
        },
        {
          "type": "STRING",
          "value": "%}"
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{#"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^#]+"
              },
              {
                "type": "STRING",
                "value": "#"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "#}"
        }
      ]
    },
    "template_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "STRING",
          "value": ":"
        }
      ]
    },
    "expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "call_expression"
        },
        {
          "type": "SYMBOL",
          "name": "member_expression"
        },
        {
          "type": "SYMBOL",
          "name": "subscript_expression"
        },
        {
          "type": "SYMBOL",
          "name": "parenthesized_expression"
        },
        {
          "type": "SYMBOL",
          "name": "array_literal"
        },
        {
          "type": "SYMBOL",
          "name": "string_literal"
        },
        {
          "type": "SYMBOL",
          "name": "number_literal"
        },
        {
          "type": "SYMBOL",
          "name": "boolean_literal"
        },
        {
          "type": "SYMBOL",
          "name": "null_literal"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "parenthesized_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "template_item"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "array_literal": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "template_item"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "call_expression": {
      "type": "PREC_LEFT",
      "value": 3,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "function",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                },
                {
                  "type": "SYMBOL",
                  "name": "member_expression"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "("
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "template_item"
            }
          },
          {
            "type": "STRING",
            "value": ")"
          }
        ]
      }
    },
    "member_expression": {
      "type": "PREC_LEFT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "object",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                },
                {
                  "type": "SYMBOL",
                  "name": "call_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "member_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "parenthesized_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "subscript_expression"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "FIELD",
            "name": "property",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            }
          }
        ]
      }
    },
    "subscript_expression": {
      "type": "PREC_LEFT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "object",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                },
                {
                  "type": "SYMBOL",
                  "name": "call_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "member_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "parenthesized_expression"
                },
                {
                  "type": "SYMBOL",
                  "name": "subscript_expression"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "template_item"
            }
          },
          {
            "type": "STRING",
            "value": "]"
          }
        ]
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "and"
            },
            {
              "type": "STRING",
              "value": "as"
            },
            {
              "type": "STRING",
              "value": "by"
            },
            {
              "type": "STRING",
              "value": "else"
            },
            {
              "type": "STRING",
              "value": "elseif"
            },
            {
              "type": "STRING",
              "value": "endblock"
            },
            {
              "type": "STRING",
              "value": "endfilter"
            },
            {
              "type": "STRING",
              "value": "endif"
            },
            {
              "type": "STRING",
              "value": "endfor"
            },
            {
              "type": "STRING",
              "value": "endmacro"
            },
            {
              "type": "STRING",
              "value": "endspaceless"
            },
            {
              "type": "STRING",
              "value": "extends"
            },
            {
              "type": "STRING",
              "value": "for"
            },
            {
              "type": "STRING",
              "value": "if"
            },
            {
              "type": "STRING",
              "value": "import"
            },
            {
              "type": "STRING",
              "value": "in"
            },
            {
              "type": "STRING",
              "value": "include"
            },
            {
              "type": "STRING",
              "value": "is"
            },
            {
              "type": "STRING",
              "value": "macro"
            },
            {
              "type": "STRING",
              "value": "matches"
            },
            {
              "type": "STRING",
              "value": "not"
            },
            {
              "type": "STRING",
              "value": "or"
            },
            {
              "type": "STRING",
              "value": "same"
            },
            {
              "type": "STRING",
              "value": "with"
            }
          ]
        }
      }
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "=="
          },
          {
            "type": "STRING",
            "value": "!="
          },
          {
            "type": "STRING",
            "value": ">="
          },
          {
            "type": "STRING",
            "value": "<="
          },
          {
            "type": "STRING",
            "value": "??"
          },
          {
            "type": "STRING",
            "value": "||"
          },
          {
            "type": "STRING",
            "value": "&&"
          },
          {
            "type": "STRING",
            "value": "|"
          },
          {
            "type": "STRING",
            "value": "+"
          },
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "STRING",
            "value": "%"
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "STRING",
            "value": ">"
          },
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "STRING",
            "value": "!"
          },
          {
            "type": "STRING",
            "value": "~"
          },
          {
            "type": "STRING",
            "value": "?"
          }
        ]
      }
    },
    "string_literal": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\"[^\"]*\""
          },
          {
            "type": "PATTERN",
            "value": "'[^']*'"
          }
        ]
      }
    },
    "number_literal": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[0-9]+(\\.[0-9]+)?"
      }
    },
    "boolean_literal": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "true"
          },
          {
            "type": "STRING",
            "value": "false"
          }
        ]
      }
    },
    "null_literal": {
      "type": "TOKEN",
